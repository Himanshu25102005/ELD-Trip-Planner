# Copy to .env for local development. Never commit .env.

# --- Required for production (DJANGO_DEBUG=False) ---
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-in-production

# True for local dev, False for Railway/Render
DJANGO_DEBUG=True

# Comma-separated hostnames (no scheme). Railway/Render auto-append RAILWAY_PUBLIC_DOMAIN / RENDER_EXTERNAL_HOSTNAME.
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated frontend origins (include https:// in production)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: match CORS for HTTPS admin/forms (defaults to https entries from CORS_ALLOWED_ORIGINS)
# CSRF_TRUSTED_ORIGINS=https://your-app.vercel.app

# Set true only if you need all *.vercel.app preview URLs (less restrictive)
# CORS_ALLOW_VERCEL_PREVIEWS=false

# --- Optional ---
# OpenRouteService key (falls back to OSRM + Nominatim if empty)
ORS_API_KEY=

# PostgreSQL connection string (optional — SQLite is fine; app has no persistent models)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Gunicorn (Railway/Render set PORT automatically)
# WEB_CONCURRENCY=2
# GUNICORN_TIMEOUT=120

# Logging
# LOG_LEVEL=INFO
